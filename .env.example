# ---- База данных (Postgres) ----
# Локальный Postgres:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/social_network
# Neon (бесплатно, https://neon.tech) — вставь строку подключения целиком:
DATABASE_URL=postgres://postgres:alexalex@localhost:5432/social_network

# ---- API-сервер ----
API_PORT=4000
# Секрет для подписи JWT (смени на длинную случайную строку!)
JWT_SECRET=change-me-to-a-long-random-secret-string
# Откуда разрешены запросы (адрес фронта)
CORS_ORIGIN=http://localhost:3000
# Папка для загруженных файлов
UPLOAD_DIR=uploads

# ---- Google OAuth (опционально) ----
# Создай OAuth-credentials: https://console.cloud.google.com/apis/credentials
#  Authorized redirect URI: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ---- Фронтенд (Next.js) ----
# Базовый адрес API (http) и WebSocket (ws)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
